FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HOST=0.0.0.0 \
    PORT=8080

WORKDIR /app

COPY requirements-cephei.txt ./
RUN pip install --no-cache-dir -r requirements-cephei.txt

COPY cephei_bot.py ./

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/health')"

EXPOSE 8080

CMD ["sh", "-c", "uvicorn cephei_bot:app --host ${HOST} --port ${PORT}"]
