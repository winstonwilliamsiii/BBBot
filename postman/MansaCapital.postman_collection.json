      ]
    },
    {
      "name": "5. JWT Token Validation",
      "description": "Validate JWT tokens used by BBBot services (Control Center API on port 5001). Run these before bots start to confirm tokens are fresh. Set jwt_token in collection variables first.",
      "item": [
        {
          "name": "Decode JWT + Assert Not Expired",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var token = pm.collectionVariables.get('jwt_token');",
                  "if (!token || token === 'YOUR_JWT_TOKEN') {",
                  "    throw new Error('[BBBot] Set jwt_token collection variable first.');",
                  "}",
                  "var parts = token.split('.');",
                  "if (parts.length !== 3) {",
                  "    throw new Error('[BBBot] jwt_token is not a valid JWT (expected 3 parts).');",
                  "}",
                  "try {",
                  "    var payload = JSON.parse(atob(parts[1]));",
                  "    pm.collectionVariables.set('jwt_decoded_sub',  payload.sub  || '');",
                  "    pm.collectionVariables.set('jwt_decoded_exp',  payload.exp  || '');",
                  "    console.log('[BBBot] JWT payload:', JSON.stringify(payload));",
                  "} catch(e) {",
                  "    throw new Error('[BBBot] Failed to decode JWT: ' + e.message);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var exp = parseInt(pm.collectionVariables.get('jwt_decoded_exp'), 10);",
                  "var nowSec = Math.floor(Date.now() / 1000);",
                  "pm.test('JWT: token is not expired', function() {",
                  "    pm.expect(exp).to.be.above(nowSec, 'Token is expired!');",
                  "});",
                  "pm.test('JWT: more than 5 minutes remaining', function() {",
                  "    pm.expect(exp - nowSec).to.be.above(300);",
                  "});",
                  "pm.test('Control Center: health returns 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{control_center_url}}/health",
              "host": ["{{control_center_url}}"],
              "path": ["health"]
            },
            "description": "Decode jwt_token, assert not expired, and hit /health to confirm server accepts it."
          }
        },
        {
          "name": "Control Center - Health (No Auth)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Control Center reachable', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{control_center_url}}/health",
              "host": ["{{control_center_url}}"],
              "path": ["health"]
            },
            "description": "Unauthenticated health check on FastAPI Control Center (Main.py on port 5001)."
          }
        }
      ]
    },
    {
      "name": "6. Airbyte Cloud API",
      "description": "Validate Airbyte Cloud credentials before bots trigger syncs. Auth: Bearer {{airbyte_api_key}}. Maps to AIRBYTE_API_KEY / AIRBYTE_CONNECTION_ID env vars in airflow/dags/Airbyt_sync_DAG_3.py.",
      "auth": {
        "type": "bearer",
        "bearer": [
          { "key": "token", "value": "{{airbyte_api_key}}", "type": "string" }
        ]
      },
      "item": [
        {
          "name": "Health Check (No Auth Required)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Airbyte Cloud reachable', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "noauth" },
            "url": {
              "raw": "{{airbyte_api_url}}/health",
              "host": ["{{airbyte_api_url}}"],
              "path": ["health"]
            },
            "description": "Unauthenticated health check. Run first to confirm network connectivity before testing API key."
          }
        },
        {
          "name": "List Workspaces (Validates API Key)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('API key accepted (200)', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('No 401 - API key is valid', function() {",
                  "    pm.expect(pm.response.code).to.not.equal(401);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    var body = pm.response.json();",
                  "    var workspaces = body.data || body.workspaces || [];",
                  "    console.log('[BBBot] Airbyte workspaces found:', workspaces.length);",
                  "    if (workspaces.length > 0) {",
                  "        pm.collectionVariables.set('airbyte_workspace_id', workspaces[0].workspaceId || workspaces[0].id);",
                  "        console.log('[BBBot] Auto-set airbyte_workspace_id:', pm.collectionVariables.get('airbyte_workspace_id'));",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{airbyte_api_url}}/workspaces",
              "host": ["{{airbyte_api_url}}"],
              "path": ["workspaces"]
            },
            "description": "Lists all workspaces. 200 = API key valid; 401 = key is wrong/expired. Test script auto-sets airbyte_workspace_id."
          }
        },
        {
          "name": "List Connections",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Connections listed successfully', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    var body = pm.response.json();",
                  "    var conns = body.data || body.connections || [];",
                  "    console.log('[BBBot] Connections found:', conns.length);",
                  "    conns.forEach(function(c) {",
                  "        console.log('  Connection:', c.connectionId || c.id, '|', c.name, '| status:', c.status);",
                  "    });",
                  "    if (conns.length > 0) {",
                  "        pm.collectionVariables.set('airbyte_connection_id', conns[0].connectionId || conns[0].id);",
                  "        console.log('[BBBot] Auto-set airbyte_connection_id:', pm.collectionVariables.get('airbyte_connection_id'));",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{airbyte_api_url}}/connections?workspaceId={{airbyte_workspace_id}}",
              "host": ["{{airbyte_api_url}}"],
              "path": ["connections"],
              "query": [{ "key": "workspaceId", "value": "{{airbyte_workspace_id}}" }]
            },
            "description": "List all connections in the workspace. Test script logs each and auto-sets airbyte_connection_id."
          }
        },
        {
          "name": "Trigger Sync (Manual Job)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var connId = pm.collectionVariables.get('airbyte_connection_id');",
                  "if (!connId || connId === 'YOUR_CONNECTION_ID') {",
                  "    throw new Error('[BBBot] Set airbyte_connection_id before triggering a sync.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sync job created (200)', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    var job = pm.response.json();",
                  "    var jobId = (job.job && job.job.id) || job.jobId || job.id;",
                  "    if (jobId) {",
                  "        pm.collectionVariables.set('airbyte_job_id', String(jobId));",
                  "        console.log('[BBBot] Sync job started. jobId:', jobId);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"connectionId\": \"{{airbyte_connection_id}}\",\n  \"jobType\": \"sync\"\n}"
            },
            "url": {
              "raw": "{{airbyte_api_url}}/jobs",
              "host": ["{{airbyte_api_url}}"],
              "path": ["jobs"]
            },
            "description": "Trigger a manual sync. Mirrors what Airbyt_sync_DAG_3.py does. Test script captures jobId."
          }
        },
        {
          "name": "Get Job Status",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jobId = pm.collectionVariables.get('airbyte_job_id');",
                  "if (!jobId || jobId === '') {",
                  "    throw new Error('[BBBot] Run Trigger Sync first to get a job ID.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Job status retrieved (200)', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    var body = pm.response.json();",
                  "    var status = (body.job && body.job.status) || body.status;",
                  "    console.log('[BBBot] Job', pm.collectionVariables.get('airbyte_job_id'), 'status:', status);",
                  "    pm.test('Job not failed', function() {",
                  "        pm.expect(status).to.not.equal('failed');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{airbyte_api_url}}/jobs/{{airbyte_job_id}}",
              "host": ["{{airbyte_api_url}}"],
              "path": ["jobs", "{{airbyte_job_id}}"]
            },
            "description": "Poll this after triggering a sync. Status cycles: pending → running → succeeded (or failed)."
          }
        }
      ]
    }
  ],
