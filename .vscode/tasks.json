{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "🚀 Start MySQL Docker Environment",
			"type": "shell",
			"command": "powershell.exe",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/scripts/launchers/start_mysql_docker.ps1"
			],
			"presentation": {
				"reveal": "always",
				"panel": "new",
				"showReuseMessage": false,
				"clear": true,
				"echo": true
			},
			"problemMatcher": [],
			"runOptions": {
				"runOn": "folderOpen"
			},
			"group": {
				"kind": "build",
				"isDefault": false
			}
		},
		{
			"label": "🐧 Start MySQL (WSL Docker Engine)",
			"type": "shell",
			"command": "powershell.exe",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$env:BENTLEY_DOCKER_MODE='wsl'; if (-not $env:BENTLEY_WSL_DISTRO) { $env:BENTLEY_WSL_DISTRO='Ubuntu' }; & '${workspaceFolder}/scripts/launchers/start_mysql_docker.ps1'"
			],
			"presentation": {
				"reveal": "always",
				"panel": "new",
				"showReuseMessage": false,
				"clear": true,
				"echo": true
			},
			"problemMatcher": []
