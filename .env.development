# ============================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION
# Moor Kingdom - Localhost (127.0.0.1)
# ============================================
# WARNING: This is for LOCAL development only
# Do NOT commit sensitive credentials to this file
# Use .env.local for machine-specific secrets

# ============================================
# ENVIRONMENT IDENTIFIER
# ============================================
ENVIRONMENT=development
DEPLOYMENT_TARGET=localhost

# ============================================
# STREAMLIT CONFIGURATION
# ============================================
# Development server runs on localhost:8501
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
STREAMLIT_LOGGER_LEVEL=debug
STREAMLIT_CLIENT_LOGGER_LEVEL=debug

# ============================================
# DATABASE CONFIGURATION - DEVELOPMENT
# ============================================
# Local MySQL development instance
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=bentley_bot_dev

# Canonical MySQL keys (used by app services)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=bentley_bot_dev

# Budget database (defaults to same as MySQL for dev)
BUDGET_MYSQL_HOST=localhost
BUDGET_MYSQL_PORT=3306
BUDGET_MYSQL_USER=root
BUDGET_MYSQL_PASSWORD=your_mysql_password
BUDGET_MYSQL_DATABASE=bentley_bot_dev

# ============================================
# FINANCIAL DATA APIs - DEVELOPMENT
# ============================================
# Yahoo Finance - No rate limiting concerns locally
YFINANCE_TIMEOUT=30
YFINANCE_BATCH_SIZE=10

# Alpaca Paper Trading (Development Key)
# Use separate paper trading account for testing
# IMPORTANT: Replace with your real paper trading keys from https://alpaca.markets
# Sign up for free paper trading account to get keys
ALPACA_API_KEY=dev_alpaca_key_placeholder
ALPACA_SECRET_KEY=dev_alpaca_secret_placeholder
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_ENVIRONMENT=paper
ALPACA_PAPER=true

# Plaid Development Credentials
# IMPORTANT: Replace with your real sandbox credentials from https://plaid.com
# Sign up for free sandbox account to get credentials
PLAID_CLIENT_ID=dev_plaid_client_id
PLAID_SECRET=dev_plaid_secret
PLAID_ENVIRONMENT=sandbox
PLAID_ENV=sandbox

# AlphaVantage API (Optional - for enhanced fundamental data)
# Get free API key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# MLflow tracking (local dev)
MLFLOW_TRACKING_URI=http://localhost:5000

# Dev-only RBAC bypass (auto-login as admin)
DEV_BYPASS_AUTH=true
DEV_BYPASS_USER=admin
DEV_BYPASS_PASSWORD=admin123

# Auto-create dev database schema on startup
AUTO_CREATE_DEV_SCHEMA=true

# Prediction Analytics - Kalshi
KALSHI_ACCESS_KEY=ea376fd0-8cd1-457d-b8d8-f417f66c33ad
KALSHI_PRIVATE_

# ============================================
# MT5 TRADING - DEVELOPMENT
# ============================================
# Local MT5 development settings
MT5_USER=dev_mt5_account_number
MT5_PASSWORD=dev_mt5_password
MT5_HOST=mt5.your-broker.com
MT5_REST_API_URL=http://localhost:8080
MT5_REST_API_TIMEOUT=30

# ============================================
# RAILWAY DEPLOYMENT - DEVELOPMENT
# ============================================
RAILWAY_PROJECT_NAME=bentley_mt5_bridge
RAILWAY_PROJECT_ID=c061b9e1-f140-472f-9f00-ffb6478cdc8d
RAILWAY_SERVICE_NAME=bentley-mt5-api

# ============================================
# APPWRITE BACKEND - DEVELOPMENT
# ============================================
APPWRITE_ENDPOINT=http://localhost:80
APPWRITE_PROJECT_ID=dev_project_id
APPWRITE_API_KEY=dev_api_key
APPWRITE_DATABASE_ID=dev_database

# ============================================
# GOOGLE SERVICES - DEVELOPMENT
# ============================================
GOOGLE_API_KEY=dev_google_api_key
GEMINI_API_KEY=dev_gemini_api_key

# ============================================
# LOGGING & DEBUGGING - DEVELOPMENT
# ============================================
LOG_LEVEL=DEBUG
ENABLE_PROFILING=true
ENABLE_ERROR_TRACING=true
DEBUG_MODE=true

# ============================================
# CACHE & SESSION MANAGEMENT
# ============================================
# Disable cache in development for rapid testing
STREAMLIT_CLIENT_CACHE_CONTROL_HEADERS=false
SESSION_TIMEOUT_MINUTES=60

# ============================================
# FILE PATHS - DEVELOPMENT
# ============================================
# Local development paths for Moor Kingdom
UPLOAD_DIRECTORY=./uploads_dev
LOG_DIRECTORY=./logs_dev
DATA_DIRECTORY=./data_dev

# ============================================
# NETWORK & SECURITY - DEVELOPMENT
# ============================================
# Permissive for local testing
CORS_ORIGINS=http://localhost:*,http://127.0.0.1:*
CSRF_PROTECTION_ENABLED=false
ALLOWED_HOSTS=localhost,127.0.0.1,moor-kingdom.local

# ============================================
# FEATURE FLAGS - DEVELOPMENT
# ============================================
ENABLE_EXPERIMENTAL_FEATURES=true
ENABLE_DEBUG_DASHBOARD=true
ENABLE_PORTFOLIO_UPLOAD=true
ENABLE_CHATBOT=true
ENABLE_BUDGET_DASHBOARD=true
ENABLE_ECONOMIC_CALENDAR=true
