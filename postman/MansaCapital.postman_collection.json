            },
            "url": {
              "raw": "{{plaid_base_url}}/transactions/get",
              "host": ["{{plaid_base_url}}"],
              "path": ["transactions", "get"]
            },
            "description": "Fetch transactions directly from Plaid"
          }
        },
        {
          "name": "Get Item Info (Direct)",
