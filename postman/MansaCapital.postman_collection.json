          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{appwrite_function_url}}/api/info",
              "host": ["{{appwrite_function_url}}"],
              "path": ["api", "info"]
            },
            "description": "Verify the Appwrite function is running and check Plaid environment"
          }
        },
        {
          "name": "Create Link Token (via Appwrite)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"winston_test_123\",\n  \"products\": [\"transactions\"],\n  \"country_codes\": [\"US\"],\n  \"language\": \"en\"\n}"
            },
            "url": {
              "raw": "{{appwrite_function_url}}/api/create_link_token",
              "host": ["{{appwrite_function_url}}"],
              "path": ["api", "create_link_token"]
