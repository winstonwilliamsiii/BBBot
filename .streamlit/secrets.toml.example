# Streamlit Secrets Configuration
# 
# For Streamlit Cloud deployment:
# 1. Go to https://share.streamlit.io/
# 2. Select your app
# 3. Click "Settings" → "Secrets"
# 4. Copy the contents below and fill in your actual values
# 5. Click "Save"
#
# For local testing with secrets:
# 1. Create .streamlit/secrets.toml (this file without .example)
# 2. Add your actual credentials
# 3. Make sure .streamlit/secrets.toml is in .gitignore

# ==============================================
# BROKER API CREDENTIALS
# ==============================================

# Alpaca Markets - US Stocks & Crypto
ALPACA_API_KEY = "your_alpaca_api_key_here"
ALPACA_SECRET_KEY = "your_alpaca_secret_key_here"
ALPACA_PAPER = "true"  # Set to "false" for live trading

# MetaTrader 5 - FOREX & Commodities Futures
MT5_API_URL = "http://localhost:8000"
MT5_USER = "your_mt5_account_number"
MT5_PASSWORD = "your_mt5_password"
MT5_HOST = "your_broker_server"
MT5_PORT = "443"

# Interactive Brokers - Global Multi-Asset
IBKR_GATEWAY_URL = "https://localhost:5000"
IBKR_ACCOUNT_ID = "your_account_id"

# ==============================================
# DATABASE CREDENTIALS (if needed for cloud)
# ==============================================

# Appwrite
APPWRITE_ENDPOINT = "https://cloud.appwrite.io/v1"
APPWRITE_PROJECT_ID = "your_project_id"
APPWRITE_API_KEY = "your_api_key"
APPWRITE_DATABASE_ID = "your_database_id"

# MySQL (if using cloud database)
MYSQL_HOST = "your_mysql_host"
MYSQL_PORT = "3306"
MYSQL_USER = "your_mysql_user"
MYSQL_PASSWORD = "your_mysql_password"
MYSQL_DATABASE = "your_database_name"

# ==============================================
# FINANCIAL DATA APIs
# ==============================================

TIINGO_API_KEY = "your_tiingo_api_key"
ALPHA_VANTAGE_API_KEY = "your_alpha_vantage_key"

# Plaid Banking Integration
PLAID_CLIENT_ID = "your_plaid_client_id"
PLAID_SECRET = "your_plaid_secret"
PLAID_ENV = "sandbox"
