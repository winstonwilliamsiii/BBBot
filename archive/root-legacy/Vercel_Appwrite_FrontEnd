# Frontend Scaffold Template
import { useState } from "react";
import { callAppwriteFunction } from "../lib/appwriteClient";

export default function Dashboard() {
  const [transactions, setTransactions] = useState([]);

  async function fetchTransactions() {
    try {
      const result = await callAppwriteFunction("get_transactions_streamlit", {
        user_id: "user123",
        limit: 10
      });
      setTransactions(result.transactions);
    } catch (err) {
      console.error(err);
    }
  }

  return (
    <div>
      <h1>BentleyBudgetBot Dashboard</h1>
      <button onClick={fetchTransactions}>Load Transactions</button>
      <ul>
        {transactions.map(tx => (
          <li key={tx.$id}>
            {tx.amount} on {tx.date}
          </li>
        ))}
      </ul>
    </div>
  );
}