# Discord Webhook URL for posting alerts
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Optional explicit portfolio symbols (highest priority)
PORTFOLIO_SYMBOLS=IONQ,QBTS,SOUN,RGTI,AMZN,NVDA

# Optional Tiingo key for portfolio quote fetch (recommended)
TIINGO_API_KEY=your_tiingo_api_key_here

# Optional AlphaVantage key for quote fallback
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Optional alias for Mansa Tech universe
MANSA_TECH_SYMBOLS=IONQ,QBTS,SOUN,RGTI,AMZN,NVDA

# Optional DB holdings user filter (used when symbols are not set above)
PORTFOLIO_USER_ID=demo_user

# Optional sharding controls for scheduled runs
PORTFOLIO_SHARD_COUNT=4
PORTFOLIO_SHARD_INDEX=

# Optional per-run symbol cap (defaults to 5 when AlphaVantage key is set)
PORTFOLIO_MAX_SYMBOLS_PER_RUN=5