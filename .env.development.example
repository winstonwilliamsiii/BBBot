# Development Environment Configuration Template
# Copy this to .env.development and fill in actual values
# Required by .github/workflows/dev-to-main.yml

ENVIRONMENT=development
DEPLOYMENT_TARGET=local
STREAMLIT_LOGGER_LEVEL=debug

# Database Configuration (Development)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=BentleyBot_Dev
MYSQL_USER=dev_user
MYSQL_PASSWORD=dev_password
MYSQL_SSL_CA=
MYSQL_SSL_VERIFY_CERT=false

# Local Development URL
STREAMLIT_APP_URL=http://localhost:8501

# API Keys (Development - use test/sandbox keys)
ALPACA_API_KEY=your_dev_api_key
ALPACA_SECRET_KEY=your_dev_secret_key
PLAID_CLIENT_ID=your_dev_client_id
PLAID_SECRET=your_dev_secret

# API Configuration
API_TIMEOUT=60
API_RETRY_ATTEMPTS=5

# Feature Flags
ENABLE_YFINANCE=true
ENABLE_PORTFOLIO_SCRAPING=true
ENABLE_DEMO_MODE=true

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# Security
ALLOW_CREDENTIAL_OVERRIDE=true
REQUIRE_HTTPS=false

# Development Tools
ENABLE_HOT_RELOAD=true
SHOW_DEBUG_INFO=true
