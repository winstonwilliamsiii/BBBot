      "description": "Direct calls to Plaid API for testing/debugging",
      "item": [
        {
          "name": "Create Link Token (Direct)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{plaid_client_id}}\",\n  \"secret\": \"{{plaid_secret}}\",\n  \"user\": {\"client_user_id\": \"winston_test_123\"},\n  \"client_name\": \"BentleyBudgetBot\",\n  \"products\": [\"transactions\"],\n  \"country_codes\": [\"US\"],\n  \"language\": \"en\"\n}"
            },
            "url": {
              "raw": "{{plaid_base_url}}/link/token/create",
              "host": ["{{plaid_base_url}}"],
              "path": ["link", "token", "create"]
            },
            "description": "Direct Plaid API call to create link token"
          }
        },
        {
          "name": "Exchange Public Token (Direct)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{plaid_client_id}}\",\n  \"secret\": \"{{plaid_secret}}\",\n  \"public_token\": \"{{plaid_public_token}}\"\n}"
            },
            "url": {
              "raw": "{{plaid_base_url}}/item/public_token/exchange",
              "host": ["{{plaid_base_url}}"],
              "path": ["item", "public_token", "exchange"]
            },
            "description": "Exchange public token for permanent access token"
          }
        },
        {
          "name": "Get Account Balances (Direct)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{plaid_client_id}}\",\n  \"secret\": \"{{plaid_secret}}\",\n  \"access_token\": \"{{plaid_access_token}}\"\n}"
            },
            "url": {
              "raw": "{{plaid_base_url}}/accounts/balance/get",
              "host": ["{{plaid_base_url}}"],
              "path": ["accounts", "balance", "get"]
            },
            "description": "Get real-time account balances"
          }
        },
        {
          "name": "Get Transactions (Direct)",
