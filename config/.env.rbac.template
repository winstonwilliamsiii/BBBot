# Appwrite RBAC Configuration
# Copy this to your .env file and fill in your actual values

# Appwrite Project Settings
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_API_KEY=your_api_key_here

# Database Configuration (if using separate MySQL tracking)
MYSQL_HOST=localhost
MYSQL_PORT=3306  
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=mansa_capital_rbac

# Mansa Capital RBAC Settings
RBAC_ADMIN_EMAIL=your_admin@email.com
RBAC_DEFAULT_ROLE=role_client
RBAC_SESSION_TIMEOUT=86400  # 24 hours in seconds

# Security Settings
RBAC_ENCRYPT_SENSITIVE_DATA=true
RBAC_AUDIT_LOG_ENABLED=true
RBAC_MAX_LOGIN_ATTEMPTS=5