          }
        }
      ]
    },
    {
      "name": "4. CashPro (Future)",
      "description": "Bank of America CashPro API - Placeholder for future integration",
      "item": [
        {
          "name": "Get Balances",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{cashpro_access_token}}" }
            ],
            "url": {
              "raw": "{{cashpro_base_url}}/balances?accountId={{account_id}}",
              "host": ["{{cashpro_base_url}}"],
              "path": ["balances"],
