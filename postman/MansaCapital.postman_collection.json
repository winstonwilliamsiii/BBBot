    {
      "name": "2. Docker Quickstart (Local Testing)",
      "description": "Test against local Docker quickstart backend (localhost:5001)",
      "item": [
        {
          "name": "Create Link Token (Docker)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"winston_test_123\"\n}"
            },
            "url": {
              "raw": "{{docker_backend_url}}/api/create_link_token",
              "host": ["{{docker_backend_url}}"],
              "path": ["api", "create_link_token"]
            },
            "description": "Test link token creation locally"
          }
        },
        {
          "name": "Exchange Token (Docker)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "public_token", "value": "{{plaid_public_token}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{docker_backend_url}}/api/set_access_token",
              "host": ["{{docker_backend_url}}"],
              "path": ["api", "set_access_token"]
            },
            "description": "Exchange token using form-encoded format (matches frontend)"
          }
        }
      ]
