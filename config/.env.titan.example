ENVIRONMENT=development

# Alpaca
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Notifications
DISCORD_WEBHOOK_URL=

# MySQL (workspace default: Docker on 127.0.0.1:3307)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=mansa_bot

# Titan tables
TITAN_TRADES_TABLE=titan_trades
TITAN_SERVICE_HEALTH_TABLE=titan_service_health
TITAN_STRATEGY_NAME=Mansa Tech - Titan Bot

# Risk + execution controls
TITAN_LIQUIDITY_BUFFER=0.20
TITAN_PREDICTION_THRESHOLD=0.50
TITAN_DRY_RUN=true
TITAN_ENABLE_TRADING=false

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
TITAN_MODEL_URI=models:/TitanRiskModel/Production

# Airflow + Airbyte
AIRFLOW_BASE_URL=http://localhost:8080
AIRBYTE_BASE_URL=http://localhost:8001
AIRBYTE_CONNECTION_ID=
