				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$p = Get-NetTCPConnection -LocalPort 5001 -State Listen -ErrorAction SilentlyContinue | Select-Object -First 1 -ExpandProperty OwningProcess; if ($p) { Stop-Process -Id $p -Force; Write-Host '✅ FastAPI stopped on port 5001' -ForegroundColor Green } else { Write-Host 'ℹ️ No FastAPI process found on port 5001' -ForegroundColor Yellow }"
			],
