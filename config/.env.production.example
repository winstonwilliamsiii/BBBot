# Production Environment Configuration Template
# Copy this to .env.production and fill in actual values
# Required by .github/workflows/dev-to-main.yml

ENVIRONMENT=production
DEPLOYMENT_TARGET=streamlit_cloud
STREAMLIT_LOGGER_LEVEL=info

# Database Configuration
MYSQL_HOST=your-tidb-host.tidbcloud.com
MYSQL_PORT=4000
MYSQL_DATABASE=your_database_name
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_SSL_CA=
MYSQL_SSL_VERIFY_CERT=false

# Streamlit Cloud URL
STREAMLIT_APP_URL=https://your-app.streamlit.app

# API Keys (Use GitHub Secrets in CI/CD)
ALPACA_API_KEY=***REPLACE_WITH_GITHUB_SECRET***
ALPACA_SECRET_KEY=***REPLACE_WITH_GITHUB_SECRET***
PLAID_CLIENT_ID=***REPLACE_WITH_GITHUB_SECRET***
PLAID_SECRET=***REPLACE_WITH_GITHUB_SECRET***
POLYMARKET_API_KEY=019c3a4c-cc8b-7d64-9c08-b40f96859958
POLYMARKET_SECRET_KEY=***REPLACE_WITH_GITHUB_SECRET***

# API Configuration
API_TIMEOUT=30
API_RETRY_ATTEMPTS=3

# Feature Flags
ENABLE_YFINANCE=true
ENABLE_PORTFOLIO_SCRAPING=true
ENABLE_DEMO_MODE=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
ALLOW_CREDENTIAL_OVERRIDE=false
REQUIRE_HTTPS=true
