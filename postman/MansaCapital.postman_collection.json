{
  "info": {
    "name": "BBBot - MansaCapital API Suite",
    "description": "Bentley Budget Bot API validation suite: Plaid, Airbyte Cloud, JWT token checks, CashPro, and Appwrite endpoints. Run the JWT and Airbyte folders first to confirm credentials before bots rely on them.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "bbbot-mansa-capital-suite",
    "version": "3.0.0"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "var jwtToken = pm.collectionVariables.get('jwt_token');",
          "if (jwtToken && jwtToken !== 'YOUR_JWT_TOKEN' && jwtToken.split('.').length === 3) {",
          "    try {",
          "        var payload = JSON.parse(atob(jwtToken.split('.')[1]));",
          "        var nowSec = Math.floor(Date.now() / 1000);",
          "        if (payload.exp && payload.exp < nowSec) {",
          "            console.warn('[BBBot] JWT token is EXPIRED. Refresh jwt_token variable.');",
          "        } else if (payload.exp) {",
          "            var minsLeft = Math.round((payload.exp - nowSec) / 60);",
          "            console.log('[BBBot] JWT valid. Expires in ' + minsLeft + ' min(s).');",
          "        }",
          "    } catch (e) {",
          "        console.warn('[BBBot] Could not decode JWT payload: ' + e.message);",
          "    }",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Appwrite Function (Production)",
      "description": "Test Plaid operations through Appwrite serverless functions",
      "item": [
