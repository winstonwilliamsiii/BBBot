# Bentley Budget Bot - Environment Configuration Template
# For Economic Data APIs and Advanced Features
# 
# Copy this file to .env and fill in your API keys to enable:
# - Economic calendar and indicators
# - Alternative data sources
# - Financial news feeds
# - Weather-based market sentiment

# ==============================================
# ECONOMIC DATA APIS (Optional but Recommended)
# ==============================================

# Bureau of Labor Statistics - US Employment & Inflation Data
# Get key at: https://data.bls.gov/api/v1/timeseries/
# Used for: Unemployment rate, CPI, wage data
BLS_API_KEY=your_bls_api_key_here

# Federal Reserve Economic Data (FRED)
# Get key at: https://fred.stlouisfed.org/docs/api/fred/
# Used for: Treasury rates, GDP growth, consumer spending, Fed rates
FRED_API_KEY=your_fred_api_key_here

# Quandl - Alternative Financial Data
# Get key at: https://www.quandl.com/account/api
# Used for: Commodity data, crypto data, real estate indicators
QUANDL_API_KEY=your_quandl_api_key_here

# Inflation API - Real-time Inflation Data
# Get key at: https://rapidapi.com/inflationapi/api/inflation-api
# Used for: Inflation rates, purchasing power, cost of living
INFLATIONAPI_KEY=your_inflationapi_key_here

# OpenWeather API - Market Sentiment (weather-based)
# Get key at: https://openweathermap.org/api
# Used for: Weather patterns affecting market sentiment
OPENWEATHER_API_KEY=your_openweather_api_key_here

# NewsAPI - Financial News Feed
# Get key at: https://newsapi.org/
# Used for: Market news, sentiment analysis
NEWSAPI_KEY=your_newsapi_key_here

# ==============================================
# MYSQL DATABASE CONFIGURATION
# ==============================================
# (These should already be configured in main .env)

# Main MySQL Database (Port 3306 - Local or Docker)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=mansa_bot

# Budget Database for Plaid Integration (Port 3306)
BUDGET_MYSQL_HOST=127.0.0.1
BUDGET_MYSQL_PORT=3306
BUDGET_MYSQL_USER=root
BUDGET_MYSQL_PASSWORD=root
BUDGET_MYSQL_DATABASE=mydb

# Operational Database for Stock Data (Port 3307 - Docker container)
BBBOT1_MYSQL_HOST=127.0.0.1
BBBOT1_MYSQL_PORT=3307
BBBOT1_MYSQL_USER=root
BBBOT1_MYSQL_PASSWORD=root
BBBOT1_MYSQL_DATABASE=bbbot1

# MLflow Database (Port 3307 - Docker container)
MLFLOW_MYSQL_HOST=127.0.0.1
MLFLOW_MYSQL_PORT=3307
MLFLOW_MYSQL_USER=root
MLFLOW_MYSQL_PASSWORD=root
MLFLOW_MYSQL_DATABASE=mlflow_db

# ==============================================
# PLAID BACKEND SERVICE
# ==============================================

# Plaid Backend URL for Link/Token exchange
# Local development: http://localhost:5001
# Production: https://your-production-url.com
PLAID_BACKEND_URL=http://localhost:5001

# ==============================================
# BROKER API CREDENTIALS
# ==============================================

# Alpaca Markets - US Stocks & Crypto
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true

# Interactive Brokers Gateway
IBKR_GATEWAY_URL=https://localhost:5000
IBKR_ACCOUNT_ID=your_account_id

# MetaTrader 5 API
MT5_API_URL=http://localhost:8000
MT5_USER=your_mt5_username
MT5_PASSWORD=your_mt5_password
MT5_HOST=MetaQuotes-Demo
MT5_PORT=443

# ==============================================
# FEATURE FLAGS & ADVANCED CONFIGURATION
# ==============================================

# Enable/Disable Features
ENABLE_ECONOMIC_CALENDAR=true
ENABLE_ADVANCED_CHARTING=true
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_ALTERNATIVE_DATA=true

# Cache Settings (in seconds)
CACHE_ECONOMIC_DATA=3600
CACHE_NEWS_DATA=1800
CACHE_MARKET_DATA=300

# ==============================================
# NOTES
# ==============================================
#
# 1. Economic Data APIs:
#    - BLS and FRED are FREE with API key registration
#    - Quandl has free tier (limited to 50 calls/day)
#    - Alternative APIs are optional - app works without them
#
# 2. Database Configuration:
#    - Port 3306: Main MySQL instance
#    - Port 3307: Secondary MySQL instance for operational data (Docker)
#    - Ensure Docker containers are running with: docker-compose up -d
#
# 3. Plaid Backend:
#    - Requires separate Node.js backend server
#    - Start with: npm start (in plaid-backend directory)
#    - Or use Docker: docker-compose up -d plaid-backend
#
# 4. Broker APIs:
#    - Alpaca: Paper trading enabled by default (ALPACA_PAPER=true)
#    - Requires live credentials for real trading
#    - MT5: Requires MetaTrader 5 terminal running locally
#
# 5. Security:
#    - Never commit actual credentials to git
#    - Use .env.local for sensitive data
#    - Rotate API keys regularly
#    - Use separate keys for development/production
