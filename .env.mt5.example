# MetaTrader 5 REST API Configuration
# Add these variables to your .env file

# MT5 REST API Server
MT5_API_URL=http://localhost:8000

# MT5 Account Credentials
MT5_USER=your_mt5_account_number
MT5_PASSWORD=your_mt5_password
MT5_HOST=broker_server_hostname
MT5_PORT=443

# Webhook Configuration (optional)
MT5_WEBHOOK_URL=https://your-server.com/webhook

# Example values:
# MT5_API_URL=http://192.168.1.100:8000
# MT5_USER=123456789
# MT5_PASSWORD=MySecurePassword123
# MT5_HOST=mt5.examplebroker.com
# MT5_PORT=443
