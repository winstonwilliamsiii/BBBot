# Bentley Budget Bot - Environment Variables Template
# 
# ⚠️ SECURITY INSTRUCTIONS:
# 1. Copy this file to .env: Copy-Item .env.example .env
# 2. Fill in your actual values in .env
# 3. NEVER commit .env to Git (it's already in .gitignore)
# 4. Only commit .env.example (with placeholder values)
#
# This template matches the structure of Appwrite_DBuild.txt

# ==============================================
# FINANCIAL DATA APIs
# ==============================================

# Tiingo API Key (Financial data provider)
# Sign up: https://www.tiingo.com/
TIINGO_API_KEY=your_tiingo_api_key_here

# Alpha Vantage API Key (Comprehensive fundamental data)
# Sign up: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here


# ==============================================
# BROKER API CONFIGURATION
# ==============================================

# Interactive Brokers (IBKR) Gateway
# Endpoint: https://localhost:5000/v1/api/iserver/accounts
# Make sure IBKR Gateway or Client Portal is running
IBKR_GATEWAY_URL=https://localhost:5000

# MetaTrader 5 REST API Server
MT5_API_URL=http://localhost:8000
MT5_USER=your_mt5_account_number
MT5_PASSWORD=your_mt5_password
MT5_HOST=your_broker_server
MT5_PORT=443

# Alpaca Trading API (Stocks & Crypto)
# Sign up: https://alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true

# ==============================================
# DATABASE CONFIGURATION
# ==============================================

# Main MySQL Database (for general app data)
MYSQL_ROOT_PASSWORD=your_secure_root_password
MYSQL_PASSWORD=your_secure_password
MYSQL_USER=root
MYSQL_DATABASE=mansa_bot
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Budget Database Configuration (for Plaid integration)
BUDGET_MYSQL_HOST=127.0.0.1
BUDGET_MYSQL_PORT=3306
BUDGET_MYSQL_USER=root
BUDGET_MYSQL_PASSWORD=your_secure_password
BUDGET_MYSQL_DATABASE=mydb

# Airbyte MySQL User (for Airbyte Cloud connections)
AIRBYTE_MYSQL_USER=airbyte
AIRBYTE_MYSQL_PASSWORD=your_secure_airbyte_password

# ==============================================  
# DCF FUNDAMENTAL ANALYSIS (Equity Valuation)
# ==============================================
# DCF Analysis uses MySQL database: Bentley_Budget
# Connection: 127.0.0.1:3306 (root@localhost)
# Required tables in Bentley_Budget database:
#   - fundamentals_annual (ticker, fiscal_year, revenue, free_cash_flow, shares_outstanding, net_debt, cash)
#   - prices_latest (ticker, price, as_of_date)
# 
# DCF Database Configuration (defaults to Bentley_Budget):
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_root_password
DB_NAME=Bentley_Budget

# ==============================================
# ML & WORKFLOW SERVICES
# ==============================================

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow.db
MLFLOW_ARTIFACT_ROOT=./mlruns

# Airflow Configuration
AIRFLOW_UID=50000
AIRFLOW_GID=0

# ==============================================
# AI ASSISTANTS
# ==============================================

# DeepSeek API Key (for Bentley AI Assistant)
# Sign up: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI API Key (for Bentley AI Assistant)
# Sign up: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ==============================================
# BANKING INTEGRATION (Plaid)
# ==============================================

# Plaid API Configuration (for Personal Budget - Bank Integration)
# Sign up: https://dashboard.plaid.com/signup
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox  # Options: sandbox, development, production
PLAID_ENVIRONMENT=sandbox
PLAID_CLIENT_ID_PRODUCTION=your_plaid_production_client_id_here
PLAID_SECRET_PRODUCTION=your_plaid_production_secret_here
PLAID_ITEMS_COLLECTION_ID=plaid_items  # Appwrite collection name for storing access tokens

# Bank of America CashPro API (Future Integration)
# BOFA_CASHPRO_API_KEY=your_bofa_api_key_here
# BOFA_CASHPRO_CLIENT_ID=your_bofa_client_id_here

# ==============================================
# APPWRITE BACKEND
# ==============================================

# Appwrite Configuration
# Get these from: https://cloud.appwrite.io/console
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id_here
APPWRITE_API_KEY=your_appwrite_api_key_here
APPWRITE_DATABASE_ID=your_database_id_here

# Appwrite Function IDs (after deployment)
# Get these after deploying functions to Appwrite Cloud
# ==============================================
BANKING_API_KEY=your_banking_api_key_here
BANKING_CLIENT_ID=your_banking_client_id_here
BANKING_CLIENT_SECRET=your_banking_client_secret_here

# ==============================================
# AIRBYTE CONFIGURATION
# ==============================================
# For Airbyte Cloud (recommended):
# 1. Get connection ID from: https://cloud.airbyte.com/workspaces/<workspace>/connections
# 2. Generate API key at: https://cloud.airbyte.com/workspaces/<workspace>/settings/api-keys
AIRBYTE_API_URL=https://api.airbyte.com/v1
AIRBYTE_CONNECTION_ID=your_connection_id_from_cloud_dashboard
AIRBYTE_API_KEY=your_api_key_from_cloud_settings

# For Local Airbyte (if using Docker Airbyte locally):
# AIRBYTE_API_URL=http://airbyte-server:8001
# AIRBYTE_CONNECTION_ID=your_local_connection_id

# ==============================================
# MLFLOW CONFIGURATION
# ==============================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=mysql+pymysql://mlflow:${MYSQL_PASSWORD}@mysql:3306/mlflow
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts

# ==============================================
# KNIME CONFIGURATION
# ==============================================
KNIME_SERVER_URL=http://localhost:8080
KNIME_SERVER_USERNAME=admin
KNIME_SERVER_PASSWORD=your_knime_password_here

# ==============================================
# DOCKER & DEPLOYMENT
# ==============================================
COMPOSE_PROJECT_NAME=bentley-budget-bot
DOCKER_BUILDKIT=1

# ==============================================
# VERCEL DEPLOYMENT (Optional)
# ==============================================
VERCEL_TOKEN=prj_m7jTfw0ZRAlNTGSeRuGk4tqQ4WOt

# ==============================================
# STREAMLIT CONFIGURATION
# ==============================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ==============================================
# AI CHATBOT CONFIGURATION (Bentley AI Assistant)
# ==============================================
# DeepSeek AI API (Recommended for financial analysis)
# Sign up: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_ENDPOINT=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# ==============================================
# PREDICTION MARKETS & TRADING PLATFORMS
# ==============================================

# Kalshi Prediction Markets API
# Sign up: https://kalshi.com/
# API Docs: https://trading-api.readme.io/reference/getting-started
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_API_SECRET=your_kalshi_api_secret_here
KALSHI_ENV=demo  # Options: demo, prod
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2  # Use https://trading-api.kalshi.com/trade-api/v2 for prod

# Polymarket Prediction Markets
# Documentation: https://docs.polymarket.com/
# Note: Polymarket uses blockchain (Polygon) - requires wallet private key
POLYMARKET_API_KEY=your_polymarket_api_key_here
POLYMARKET_PRIVATE_KEY=your_polymarket_wallet_private_key_here
POLYMARKET_BASE_URL=https://api.polymarket.com

# ==============================================
# BANKING APIs (Optional Integrations)
# ==============================================

# Bank of America API
# Documentation: https://developer.bankofamerica.com/
# Note: Requires business account and API approval
BOA_API_KEY=your_boa_api_key_here
BOA_API_SECRET=your_boa_api_secret_here
BOA_CLIENT_ID=your_boa_client_id_here
BOA_BASE_URL=https://api.bankofamerica.com

# Alternative LLM providers (OpenAI, Anthropic, etc.)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ==============================================
# ECONOMIC DATA APIs (For Bentley AI Context)
# ==============================================
# Bureau of Labor Statistics (BLS)
BLS_API_KEY=your_bls_api_key_here

# Census Bureau API
CENSUS_API_KEY=your_census_api_key_here
